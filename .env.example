# Solana / base layer
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── MagicBlock PER / Private Payments ───────────────────────────────────────
#
# TEE RPC (Private Ephemeral Rollup, Intel TDX enclave)
#   Devnet: https://devnet-tee.magicblock.app
#   Mainnet: https://mainnet-tee.magicblock.app
#   Live check: node scripts/check-magicblock.mjs
#   Auth token appended at runtime after getAuthToken() from SDK.
NEXT_PUBLIC_MAGICBLOCK_TEE_RPC_URL=https://devnet-tee.magicblock.app

# Router RPC (non-TEE ephemeral rollup; used for non-private ER execution)
NEXT_PUBLIC_MAGICBLOCK_ROUTER_RPC_URL=https://devnet-router.magicblock.app

# Private Payments API base URL.
#   Not publicly available — request access via discord.com/invite/MBkdC3gxcv
#   Adapter fails closed when unset.
NEXT_PUBLIC_MAGICBLOCK_PRIVATE_PAYMENTS_URL=

# Set to "true" ONLY after:
#   1. Anchor upgraded to 0.32.1 (currently 0.30.1 — isolate before touching Rust)
#   2. #[ephemeral] / #[delegate] / #[commit] macros added to shielded_pool / lending_pool
#   3. Re-confirmed devnet round-trip (deposit → flush_epoch → withdraw) passes
NEXT_PUBLIC_PER_ENABLED=

# MagicBlock on-chain program IDs (from SDK 0.8.x + docs 2026-05; do not change)
NEXT_PUBLIC_MAGICBLOCK_PERMISSION_PROGRAM_ID=ACLseoPoyC3cBqoUtkbjZ4aDrkurZW86v19pXz2XQnp1
NEXT_PUBLIC_MAGICBLOCK_DELEGATION_PROGRAM_ID=DELeGGvXpWV2fqJUhqcF5ZSYMS4JTLjteaAMARRSaeSh

# ─── IKA Solana pre-alpha dWallet/FutureSign ─────────────────────────────────
NEXT_PUBLIC_IKA_ENABLED=true
IKA_GRPC_URL=https://pre-alpha-dev-1.ika.ika-network.net:443
IKA_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY

# ─── Encrypt Solana pre-alpha confidential-compute ───────────────────────────
NEXT_PUBLIC_ENCRYPT_ENABLED=true
ENCRYPT_GRPC_URL=https://pre-alpha-dev-1.encrypt.ika-network.net:443
ENCRYPT_PROGRAM_ID=4ebfzWdKnrnGseuQpezXdG8yCdHqwQ1SSBHD3bWArND8
# Optional. If unset, scripts/check-encrypt.mjs discovers the active devnet key from Encrypt program accounts.
ENCRYPT_NETWORK_PUBLIC_KEY_HEX=
ENCRYPT_PROBE_HEALTH_RATIO_BPS=15000
ENCRYPT_PROBE_LOAN_PDA=

# ─── Umbra SDK (SPL/Token-2022 encrypted balances) ──────────────────────────
# Official SDK: @umbra-privacy/sdk@4.0.0. Devnet supports integration testing.
# Native SOL exits need wSOL wrapping before Umbra actions can be submitted.
NEXT_PUBLIC_UMBRA_ENABLED=
NEXT_PUBLIC_UMBRA_NETWORK=devnet
NEXT_PUBLIC_UMBRA_PROGRAM_ID=DSuKkyqGVGgo4QtPABfxKJKygUDACbUhirnuv63mEpAJ
NEXT_PUBLIC_UMBRA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_UMBRA_RPC_WS_URL=wss://api.devnet.solana.com
NEXT_PUBLIC_UMBRA_INDEXER_URL=https://utxo-indexer.api-devnet.umbraprivacy.com
NEXT_PUBLIC_UMBRA_RELAYER_URL=https://relayer.api-devnet.umbraprivacy.com
NEXT_PUBLIC_UMBRA_MINT_ADDRESS=
NEXT_PUBLIC_UMBRA_FUNDED_FLOW_STATUS=not-run
NEXT_PUBLIC_UMBRA_FUNDED_FLOW_MINT=
NEXT_PUBLIC_UMBRA_FUNDED_FLOW_ASSET=wsol
NEXT_PUBLIC_UMBRA_FUNDED_FLOW_DEPOSIT_SIGNATURE=
NEXT_PUBLIC_UMBRA_FUNDED_FLOW_WITHDRAW_SIGNATURE=
NEXT_PUBLIC_UMBRA_FUNDED_FLOW_BLOCKER=No funded devnet Umbra token action has been confirmed yet.

# Same values without NEXT_PUBLIC_ are read by scripts/check-umbra.mjs and scripts/umbra-smoke.mjs.
UMBRA_NETWORK=devnet
UMBRA_PROGRAM_ID=DSuKkyqGVGgo4QtPABfxKJKygUDACbUhirnuv63mEpAJ
UMBRA_INDEXER_URL=https://utxo-indexer.api-devnet.umbraprivacy.com
UMBRA_RELAYER_URL=https://relayer.api-devnet.umbraprivacy.com
UMBRA_FUNDED_MINT=So11111111111111111111111111111111111111112
UMBRA_FUNDED_ASSET_KIND=wsol
UMBRA_FUNDED_AMOUNT_BASE_UNITS=1000000
UMBRA_FUNDED_WITHDRAW=true
